{
  "_comment": "Secrets MANIFEST only — names and sources, never values. Values live in OS keychain or env.",
  "version": "1.0",
  "updated": "2026-04-19",
  "entries": [
    {
      "name": "ANTHROPIC_API_KEY",
      "source": "env | macOS keychain (security find-generic-password -s anthropic)",
      "purpose": "Claude API calls",
      "required": true
    },
    {
      "name": "GH_TOKEN",
      "source": "gh auth token",
      "purpose": "GitHub ops",
      "required": true
    },
    {
      "name": "VERCEL_TOKEN",
      "source": "~/.vercel/auth.json -> token",
      "purpose": "Vercel deploys",
      "required": false
    },
    {
      "name": "LINKEDIN_TOKEN",
      "source": "OAuth refresh (valid until 2026-06-17)",
      "purpose": "LinkedIn native posting",
      "required": false,
      "expires": "2026-06-17"
    },
    {
      "name": "SUPABASE_ACCESS_TOKEN",
      "source": "env",
      "purpose": "Supabase admin",
      "required": false
    },
    {
      "name": "ZAPIER_MCP_URL",
      "source": "~/.claude/settings.local.json -> mcpServers.Zapier.url",
      "purpose": "Zapier webhooks",
      "required": false
    }
  ],
  "rotation_policy": {
    "default_days": 90,
    "linkedin_days": "until OAuth expiry",
    "check_frequency": "monthly (§13.4)"
  }
}
